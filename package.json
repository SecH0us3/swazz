{
  "name": "swazz",
  "version": "1.0.0",
  "private": true,
  "description": "Smart API Fuzzer — find crashes before your users do",
  "workspaces": [
    "packages/web",
    "packages/edge",
    "packages/rag",
    "demo",
    "docs"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=packages/edge",
    "dev:frontend": "npm run dev --workspace=packages/web",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run build --workspace=packages/web",
    "deploy:api": "npm run deploy --workspace=packages/edge",
    "deploy:web": "npm run deploy --workspace=packages/web",
    "deploy:demo": "npm run deploy --workspace=demo",
    "deploy:all": "npm run deploy:web",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "wrangler": "^4.112.0"
  },
  "dependencies": {
    "fake-indexeddb": "^6.2.5"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true,
    "onnxruntime-node@1.24.3": true,
    "protobufjs@7.6.5": true,
    "sharp@0.34.5": true,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true,
    "workerd@1.20260701.1": true,
    "workerd@1.20260704.1": true
  }
}
