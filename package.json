{
  "name": "swazz",
  "version": "1.0.0",
  "private": true,
  "description": "Smart API Fuzzer — find crashes before your users do",
  "workspaces": [
    "packages/web",
    "packages/edge"
  ],
  "scripts": {
    "dev:backend": "cd packages/container && go run main.go serve",
    "dev:frontend": "VITE_PROXY_URL=http://localhost:8080 npm run dev --workspace=packages/web",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run build --workspace=packages/web",
    "deploy:api": "npm run deploy --workspace=packages/edge",
    "deploy:web": "npm run deploy --workspace=packages/web",
    "deploy:all": "concurrently \"npm run deploy:api\" \"npm run deploy:web\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "wrangler": "^4.71.0"
  }
}
