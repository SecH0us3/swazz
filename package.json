{
  "name": "swazz",
  "version": "1.0.0",
  "private": true,
  "description": "Smart API Fuzzer — find crashes before your users do",
  "workspaces": [
    "packages/core",
    "packages/worker",
    "packages/web",
    "packages/cli"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/web",
    "dev:worker": "npm run dev --workspace=packages/worker",
    "build": "npm run build --workspace=packages/core && npm run build --workspace=packages/web",
    "test": "npm run test --workspace=packages/core",
    "deploy:worker": "npm run deploy --workspace=packages/worker",
    "deploy:web": "npm run deploy --workspace=packages/web"
  },
  "devDependencies": {
    "wrangler": "^4.80.0"
  }
}
