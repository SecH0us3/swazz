# === DOCKERFILE FOR AI REMEDIATION RUNNER ===
# This "Fat" image contains the necessary tools (git, gh, glab) to create Pull Requests
# as well as runtimes (Node.js, Python) and CLIs (agy, claude) for AI models.

# Stage 1: Build Go Application
FROM --platform=$BUILDPLATFORM golang:1.26.4-alpine3.23@sha256:f23e8b227fb4493eabe03bede4d5a32d04092da71962f1fb79b5f7d1e6c2a17f AS builder
ARG TARGETOS
ARG TARGETARCH
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
ARG DOCKER_TAG=dev
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build -ldflags="-s -w -X main.Version=${DOCKER_TAG}" -o swazz-engine .

# Stage 2: Runtime image with dependencies
FROM alpine:3.21

ENV GOMEMLIMIT=230MiB
ENV PATH="/home/swazz/.local/bin:${PATH}"

# Install Git, GitHub CLI (gh), GitLab CLI (glab) and runtimes for AI CLI tools
RUN apk update && apk add --no-cache \
    git \
    github-cli \
    glab \
    curl \
    jq \
    bash \
    nodejs \
    npm \
    python3 \
    py3-pip \
    pipx

# Create a non-root user to run the app and tools securely
RUN addgroup -S swazz && adduser -S swazz -G swazz
USER swazz:swazz

# Install Antigravity CLI (agy)
RUN pipx install antigravity-cli

# Install Claude CLI (community Node.js package as example)
RUN npm config set prefix '~/.npm-global'
ENV PATH="/home/swazz/.npm-global/bin:${PATH}"
RUN npm install -g @anthropic-ai/claude-cli || npm install -g claude-cli

COPY --from=builder /app/swazz-engine /swazz-engine
WORKDIR /
EXPOSE 8080

ENTRYPOINT ["/swazz-engine"]
CMD ["serve"]
