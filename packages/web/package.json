{
    "name": "@swazz/web",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "sync-docs": "node -e \"const fs = require('fs'); fs.copyFileSync('../../ai.txt', 'public/ai.txt'); fs.copyFileSync('../../llms.txt', 'public/llms.txt'); fs.copyFileSync('../../llms-full.txt', 'public/llms-full.txt');\"",
        "predev": "npm run sync-docs",
        "prebuild": "npm run sync-docs",
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "deploy": "npm run build && wrangler deploy",
        "test": "vitest run"
    },
    "dependencies": {
        "@simplewebauthn/browser": "^13.3.0",
        "qrcode": "^1.5.4",
        "react": "^19.0.0",
        "react-dom": "^19.2.7",
        "react-virtuoso": "^4.18.7",
        "zustand": "^5.0.14"
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^26.1.0",
        "@types/qrcode": "^1.5.6",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^6.0.3",
        "fake-indexeddb": "^6.2.5",
        "jsdom": "^29.1.1",
        "typescript": "^6.0.3",
        "vite": "^8.0.16",
        "vitest": "^4.1.9"
    }
}
